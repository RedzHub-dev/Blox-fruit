-- [[ 6. LOGIC SĂN MỤC TIÊU - FIXED ]]
_G.TargetPlayer = nil
local StartFlyTime, StartAttackTime = 0, 0
local IsReached = false
local startSession = os.time()
local lastHopTime = os.time()
local CurrentTween = nil

local function GetRandomPlayer()
    local players = Players:GetPlayers()
    local validTargets = {}
    for _, p in pairs(players) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            table.insert(validTargets, p)
        end
    end
    return #validTargets > 0 and validTargets[math.random(1, #validTargets)] or nil
end

NextBtn.MouseButton1Click:Connect(function() _G.TargetPlayer = nil end)
HopBtn.MouseButton1Click:Connect(function() HopServer() end)

task.spawn(function()
    while task.wait(0.2) do
        pcall(function()
            local now = os.time()
            TimeL.Text = string.format("Time : %dh%dm%ds", math.floor((now-startSession)/3600), math.floor(((now-startSession)%3600)/60), (now-startSession)%60)
            BountyL.Text = "Bounty: " .. tostring(lp.leaderstats["Bounty/Honor"].Value):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
            
            if (now - lastHopTime) >= 100 then lastHopTime = now; HopServer() end
            
            -- Kiểm tra mục tiêu hiện tại
            local target = _G.TargetPlayer
            local isTargetValid = target and target.Parent and target.Character and target.Character:FindFirstChild("HumanoidRootPart") and target.Character:FindFirstChild("Humanoid") and target.Character.Humanoid.Health > 0

            if isTargetValid then
                local hrp = lp.Character.HumanoidRootPart
                local thit = target.Character.HumanoidRootPart
                local health = target.Character.Humanoid.Health
                local dist = (hrp.Position - thit.Position).Magnitude
                
                -- Update Status theo yêu cầu (Gom tất cả vào 1 dòng)
                TargetL.Text = string.format("Hunting: %s | ID: %d | HP: %d | Dist: %d", target.Name, target.UserId, math.floor(health), math.floor(dist))
                
                EnbleHaki(); EquipWeapon()
                
                if CurrentTween then CurrentTween:Cancel() end
                CurrentTween = TweenService:Create(hrp, TweenInfo.new(dist/350, Enum.EasingStyle.Linear), {CFrame = thit.CFrame * CFrame.new(0, 7, 0)})
                CurrentTween:Play()

                if dist < 10 then 
                    if not IsReached then 
                        IsReached = true 
                        StartAttackTime = os.time() 
                    elseif (os.time() - StartAttackTime) >= 12 then 
                        _G.TargetPlayer = nil -- Đánh xong 12s, reset tìm người mới
                    end
                else
                    IsReached = false
                    if (os.time() - StartFlyTime) >= 45 then _G.TargetPlayer = nil end
                end
            else
                -- Khi không có mục tiêu hoặc mục tiêu chết, mới đi tìm người khác
                if CurrentTween then CurrentTween:Cancel() end
                TargetL.Text = "Status: Searching for targets..."
                local newTarget = GetRandomPlayer()
                if newTarget then
                    _G.TargetPlayer = newTarget
                    StartFlyTime = os.time()
                    IsReached = false
                end
            end
        end)
    end
end)

